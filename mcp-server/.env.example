# Upstash (même base que web/)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Context.dev (résolution de marque, 20 crédits/domaine)
CONTEXT_DEV_API_KEY=

# Marque émettrice par défaut
SENDER_DOMAIN=pigment.com

# Base des URLs de landing pages retournées par les tools.
# localhost en dev — À FLIPPER vers le domaine de prod avant tout envoi réel.
SITE_BASE_URL=http://localhost:3000

# Routage de canal (tool route_lead : sms / linkedin / email).
# Clé API Anthropic — active le juge Claude qui évalue l'activité LinkedIn.
# Sans clé, le routage retombe sur une heuristique déterministe (build/tests
# verts sans clé). Secret.
ANTHROPIC_API_KEY=
# Optionnel : modèle du juge d'activité (Haiku par défaut, classifieur bon marché).
ROUTING_JUDGE_MODEL=claude-haiku-4-5
