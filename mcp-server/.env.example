# Upstash (même base que web/)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Context.dev (résolution de marque, 20 crédits/domaine)
CONTEXT_DEV_API_KEY=

# Marque émettrice par défaut
SENDER_DOMAIN=pigment.com

# Base des URLs de landing pages retournées par les tools.
# localhost en dev — À FLIPPER vers le domaine de prod avant tout envoi réel.
SITE_BASE_URL=http://localhost:3000

# FullEnrich (enrichissement email/téléphone via MCP).
# Token bearer d'un compte FullEnrich (le MCP hébergé se connecte normalement
# en OAuth navigateur ; en headless on passe le token en header). Secret.
FULLENRICH_MCP_TOKEN=
# Endpoint MCP FullEnrich. Par défaut l'endpoint hébergé si non défini.
FULLENRICH_MCP_URL=https://mcp.fullenrich.com/mcp
# Optionnel : fige le nom du tool d'enrichissement au lieu de le découvrir.
FULLENRICH_ENRICH_TOOL=
